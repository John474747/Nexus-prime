# Clerk Authentication (get from clerk.com)
VITE_CLERK_PUBLISHABLE_KEY=pk_live_...

# Clerk proxy URL — only needed on Replit, leave blank on Vercel
VITE_CLERK_PROXY_URL=

# API server base URL — set to your deployed API server URL on Vercel
# Leave blank to use relative /api/* calls (when frontend + API are same origin)
VITE_API_BASE_URL=https://your-api-server.vercel.app
